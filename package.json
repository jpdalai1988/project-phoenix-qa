{
  "name": "project-phoenix-qa",
  "version": "1.0.0",
  "description": "AI-Augmented QA Automation Framework",
  "scripts": {
    "test:api": "playwright test src/tests/api/ --project=chromium",
    "test:ui": "playwright test src/tests/ui/",
    "test:all": "npm run test:api && npm run test:ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report:html": "playwright show-report",
    "report:allure": "allure generate allure-results --clean -o allure-report && allure open allure-report",
    "codegen": "playwright codegen",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "ai:generate": "ts-node src/ai/testGenerator.ts",
    "heal": "ts-node src/ai/selfHealing.ts",
    "prepare": "husky install"
  },
  "keywords": [
    "playwright",
    "ai-testing",
    "self-healing",
    "e2e",
    "automation"
  ],
  "author": "Jitendra Prafull Dalai",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "allure-playwright": "^2.15.1",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "eslint": "^8.54.0",
    "husky": "^8.0.3",
    "openai": "^4.20.0",
    "prettier": "^3.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  }
}
